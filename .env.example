# Supabase connection — copy this file to `.env.local` and fill in your values.
# Find both under: Supabase Dashboard → Project Settings → Data API / API Keys.
#
# These use the NEXT_PUBLIC_ prefix because the anon (public) key is designed to
# be exposed to the browser; it is protected by Row Level Security. Never put the
# service_role / secret key here.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
